# Bundle non-Qt third-party libraries into the macOS .app bundle.
# Generated by CMake from macos_bundle_fixup.cmake.in — do not edit.
#
# qt_generate_deploy_app_script handles Qt frameworks/plugins but not
# libraries such as Qwt or GSL.  This script copies them into the
# Frameworks directory and rewrites load-path references so the
# application works when relocated (e.g. in a .dmg).

set(_fw_dir "${CMAKE_INSTALL_PREFIX}/strata.app/Contents/Frameworks")
set(_exe "${CMAKE_INSTALL_PREFIX}/strata.app/Contents/MacOS/strata")
file(MAKE_DIRECTORY "${_fw_dir}")

set(_libs "@_MACOS_BUNDLE_LIBS@")
set(_names)

foreach(_lib IN LISTS _libs)
    if(NOT EXISTS "${_lib}")
        message(WARNING "macos_bundle_fixup: skipping missing library: ${_lib}")
        continue()
    endif()

    get_filename_component(_name "${_lib}" NAME)
    get_filename_component(_real "${_lib}" REALPATH)
    get_filename_component(_real_name "${_real}" NAME)

    # Copy the actual file into Frameworks
    file(COPY "${_real}" DESTINATION "${_fw_dir}")
    if(NOT "${_real_name}" STREQUAL "${_name}")
        file(RENAME "${_fw_dir}/${_real_name}" "${_fw_dir}/${_name}")
    endif()

    # Set the library's own install-name id to @rpath
    execute_process(
        COMMAND install_name_tool -id "@rpath/${_name}" "${_fw_dir}/${_name}")

    list(APPEND _names "${_name}")
endforeach()

# ---- helper: rewrite references inside a Mach-O binary ----
macro(_fixup_refs _binary)
    execute_process(COMMAND otool -L "${_binary}" OUTPUT_VARIABLE _otool)
    string(REPLACE "\n" ";" _lines "${_otool}")
    foreach(_dep_name IN LISTS _names)
        foreach(_line IN LISTS _lines)
            if("${_line}" MATCHES "${_dep_name}")
                string(STRIP "${_line}" _trimmed)
                string(REGEX REPLACE " \\(.*\\)$" "" _old "${_trimmed}")
                if(NOT "${_old}" STREQUAL "@rpath/${_dep_name}")
                    execute_process(
                        COMMAND install_name_tool -change
                            "${_old}" "@rpath/${_dep_name}" "${_binary}")
                endif()
                break()
            endif()
        endforeach()
    endforeach()
endmacro()

# Fix the main executable
_fixup_refs("${_exe}")

# Fix cross-references between bundled libraries
foreach(_name IN LISTS _names)
    _fixup_refs("${_fw_dir}/${_name}")
endforeach()

message(STATUS "Bundled non-Qt libraries: ${_names}")
